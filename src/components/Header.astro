---
interface Props {
  light?: boolean;
}
const { light = false } = Astro.props;
---

<header class:list={["site-header", { "dark-section": !light, "light-header": light }]} id="site-header">
  <div class="header-inner" id="header-inner">
    <a href="/TaxSpecialistLandingEN/" class="header-logo">
      Investment <span class="logo-accent">Lawyer</span>
    </a>

    <nav class="header-nav" aria-label="Main navigation">
      <a href="/TaxSpecialistLandingEN/services/#securities" class="nav-link nav-link-anim">Securities</a>
      <a href="/TaxSpecialistLandingEN/services/#taxes" class="nav-link nav-link-anim">Tax</a>
      <a href="/TaxSpecialistLandingEN/services/#corporate" class="nav-link nav-link-anim">Corporate</a>
      <a href="/TaxSpecialistLandingEN/expert/" class="nav-link nav-link-anim">Expert</a>
    </nav>

    <a href="#cta" class="nav-cta">Contact</a>

    <button class="mobile-toggle" aria-label="Menu" id="mobile-menu-btn">
      <span class="toggle-bar"></span>
      <span class="toggle-bar"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <a href="/TaxSpecialistLandingEN/services/#securities" class="mobile-link">Securities</a>
    <a href="/TaxSpecialistLandingEN/services/#taxes" class="mobile-link">International Tax</a>
    <a href="/TaxSpecialistLandingEN/services/#corporate" class="mobile-link">Corporate Law</a>
    <a href="/TaxSpecialistLandingEN/expert/" class="mobile-link">About the Expert</a>
    <a href="#contact" class="mobile-link mobile-link-cta">Contact</a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    padding: 0 24px;
    transition: all 0.6s var(--easing-smooth);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 5rem;
    max-width: 1200px;
    margin: 0 auto;
    transition: all 0.6s var(--easing-smooth);
  }

  /* ===== Nav Pill state ===== */
  .site-header.is-pill {
    padding-top: 16px;
    justify-content: center;
    background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
  }
  .site-header.is-pill .header-inner {
    max-width: 860px;
    height: 3.5rem;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(0, 0, 0, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    padding: 0 36px;
  }

  /* Hide when scrolling down */
  .site-header.is-hidden {
    transform: translateY(-100%);
  }

  /* ===== Light header (for pages with light background) ===== */
  .site-header.light-header .header-logo {
    color: #2A2622;
  }
  .site-header.light-header .nav-link {
    color: rgba(42, 38, 34, 0.5);
  }
  .site-header.light-header .nav-link:hover {
    color: #2A2622;
  }
  .site-header.light-header .nav-cta {
    color: #2A2622;
    border-color: rgba(42, 38, 34, 0.2);
  }
  .site-header.light-header .nav-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .site-header.light-header .toggle-bar {
    background: #2A2622;
  }
  /* Pill state: dark bg → restore white text */
  .site-header.light-header.is-pill {
    background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 70%, transparent 100%);
  }
  .site-header.light-header.is-pill .header-inner {
    background: rgba(0, 0, 0, 0.75);
  }
  .site-header.light-header.is-pill .header-logo {
    color: #fff;
  }
  .site-header.light-header.is-pill .logo-accent {
    color: var(--accent);
  }
  .site-header.light-header.is-pill .nav-link {
    color: rgba(234, 231, 224, 0.5);
  }
  .site-header.light-header.is-pill .nav-link:hover {
    color: #eae7e0;
  }
  .site-header.light-header.is-pill .nav-cta {
    color: #eae7e0;
    border-color: rgba(255, 255, 255, 0.2);
  }
  .site-header.light-header.is-pill .nav-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .site-header.light-header.is-pill .toggle-bar {
    background: #eae7e0;
  }

  /* ===== Logo ===== */
  .header-logo {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.1;
    color: #fff;
    text-decoration: none;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: opacity 0.3s ease;
  }
  .header-logo:hover { opacity: 0.8; }
  .logo-accent {
    color: var(--accent);
    font-weight: 400;
    font-style: italic;
  }

  /* Pill state: compress logo */
  .site-header.is-pill .header-logo {
    font-size: 1rem;
  }
  .site-header.is-pill .header-logo .logo-accent { margin-left: 0.3em; }

  /* ===== Desktop nav ===== */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(234, 231, 224, 0.5);
    text-decoration: none;
    transition: color 0.3s ease;
    position: relative;
  }
  /* Underline via global .nav-link-anim::after (scaleX pattern) */
  .nav-link:hover {
    color: var(--text);
  }

  /* ===== CTA button ===== */
  .nav-cta {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 24px;
    padding: 10px 24px;
    transition: all 0.4s var(--easing-smooth);
  }
  .nav-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(43, 76, 126, 0.08);
  }

  /* Pill state: smaller CTA */
  .site-header.is-pill .nav-cta {
    padding: 7px 18px;
    font-size: 0.6rem;
  }

  /* ===== Mobile toggle ===== */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .toggle-bar {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--text);
    transition: all 0.3s var(--easing-smooth);
  }
  .mobile-toggle.open .toggle-bar:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }
  .mobile-toggle.open .toggle-bar:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  /* ===== Mobile menu ===== */
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 0 1.5rem;
    gap: 0;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-10px);
    transition: max-height 0.4s var(--easing-smooth),
                opacity 0.4s var(--easing-smooth),
                transform 0.4s var(--easing-smooth),
                padding 0.4s var(--easing-smooth);
  }
  .mobile-menu.open {
    max-height: 320px;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
    padding: 0 1.5rem 1.2rem;
    background: rgba(0, 0, 0, 0.95);
  }
  .mobile-link {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--text);
    text-decoration: none;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.3s ease, padding-left 0.3s ease;
  }
  .mobile-link:hover {
    color: var(--accent);
    padding-left: 0.5rem;
  }
  .mobile-link-cta {
    color: var(--accent);
    border-bottom: none;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .header-nav { display: none; }
    .nav-cta { display: none; }
    .mobile-toggle { display: flex; }
    .mobile-menu { display: flex; }
    .site-header.is-pill .header-inner {
      border-radius: 0;
      max-width: 100%;
      background: rgba(0, 0, 0, 0.85);
    }
    .site-header.menu-open {
      background: rgba(0, 0, 0, 0.95);
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  // Mobile menu
  if (btn && menu) {
    btn.addEventListener('click', () => {
      btn.classList.toggle('open');
      menu.classList.toggle('open');
      header?.classList.toggle('menu-open');
    });
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        btn?.classList.remove('open');
        menu.classList.remove('open');
        header?.classList.remove('menu-open');
      });
    });
  }

  // Nav pill + auto-hide on scroll
  if (header) {
    let lastScroll = 0;
    const heroHeight = window.innerHeight * 0.8;

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;

      // Pill state: activate after scrolling past hero
      header.classList.toggle('is-pill', scrollY > heroHeight);

      // Auto-hide on scroll down, show on scroll up
      if (scrollY > heroHeight) {
        if (scrollY > lastScroll + 10) {
          header.classList.add('is-hidden');
        } else if (scrollY < lastScroll - 10) {
          header.classList.remove('is-hidden');
        }
      } else {
        header.classList.remove('is-hidden');
      }

      lastScroll = scrollY;
    }, { passive: true });
  }
</script>
