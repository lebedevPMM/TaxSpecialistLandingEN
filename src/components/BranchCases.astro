---
interface Props {
  cases: Array<{
    title: string;
    description: string;
    caseStudy: string;
  }>;
}

const { cases } = Astro.props;
---

<section class="branch-cases">
  <div class="cases-header container mx-auto px-4 max-w-7xl pt-24 pb-8">
    <div class="rv">
      <span class="section-label">Практика</span>
      <h2 class="section-heading font-serif">Результаты работы</h2>
    </div>
  </div>

  <!-- Full-width carousel -->
  <div class="carousel-viewport" data-carousel>
    <div class="carousel-track" id="cases-track">
      {cases.map((c, i) => (
        <article class="case-slide glass">
          <div class="case-inner">
            <h3 class="case-title font-serif">{c.title}</h3>
            <p class="case-description" set:html={c.description} />
            <div class="case-study">
              <span class="case-label">Кейс из практики</span>
              <p class="case-quote font-serif" set:html={c.caseStudy} />
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Navigation -->
    <div class="carousel-nav container mx-auto px-4 max-w-7xl">
      <div class="carousel-dots" id="cases-dots"></div>
      <div class="carousel-arrows">
        <button class="carousel-arrow" id="cases-prev" aria-label="Предыдущий кейс">&larr;</button>
        <button class="carousel-arrow" id="cases-next" aria-label="Следующий кейс">&rarr;</button>
      </div>
    </div>
  </div>
</section>

<style>
  .branch-cases {
    background: var(--bg);
    padding-bottom: 4rem;
  }

  /* Carousel viewport — full width, no overflow visible for peek effect */
  .carousel-viewport {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.6s var(--easing-smooth);
    cursor: grab;
  }
  .carousel-track.dragging {
    transition: none;
    cursor: grabbing;
  }

  .case-slide {
    flex: 0 0 min(85vw, 800px);
    margin-right: 2rem;
    min-height: 400px;
    border-radius: 24px;
  }
  .case-slide:first-child {
    margin-left: max(calc((100vw - 80rem) / 2 + 1rem), 2rem);
  }
  .case-slide:last-child {
    margin-right: max(calc((100vw - 80rem) / 2 + 1rem), 2rem);
  }

  .case-inner {
    padding: 3rem;
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .case-title {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 400;
    color: var(--text);
    margin-bottom: 1.2rem;
  }

  .case-description {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .case-study {
    background: var(--bg-alt);
    padding: 1.5rem 2rem;
    border-left: 2px solid var(--accent);
  }

  .case-label {
    display: block;
    text-transform: uppercase;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .case-quote {
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text);
    line-height: 1.7;
    margin: 0;
  }

  /* Navigation */
  .carousel-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
  }

  .carousel-dots {
    display: flex;
    gap: 0.5rem;
  }
  .carousel-dots .dot {
    width: 2rem;
    height: 2px;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    cursor: pointer;
    transition: all 0.4s ease;
    padding: 0;
  }
  .carousel-dots .dot.active {
    background: var(--accent);
    width: 3rem;
  }

  .carousel-arrows {
    display: flex;
    gap: 0.75rem;
  }
  .carousel-arrow {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.3s var(--easing-smooth);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .carousel-arrow:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(43, 76, 126, 0.08);
  }

  @media (max-width: 768px) {
    .case-slide {
      flex: 0 0 90vw;
      margin-right: 1rem;
    }
    .case-slide:first-child { margin-left: 1rem; }
    .case-slide:last-child { margin-right: 1rem; }
    .case-inner { padding: 2rem; }
  }
</style>

<script>
  const track = document.getElementById('cases-track') as HTMLElement;
  const dotsContainer = document.getElementById('cases-dots') as HTMLElement;
  const prevBtn = document.getElementById('cases-prev');
  const nextBtn = document.getElementById('cases-next');

  if (track && dotsContainer) {
    const slides = track.querySelectorAll('.case-slide');
    let current = 0;

    // Create dots
    slides.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = `dot${i === 0 ? ' active' : ''}`;
      dot.addEventListener('click', () => goTo(i));
      dotsContainer.appendChild(dot);
    });

    function goTo(index: number) {
      current = Math.max(0, Math.min(index, slides.length - 1));
      const slide = slides[current] as HTMLElement;
      const offset = slide.offsetLeft - parseInt(getComputedStyle(slides[0] as HTMLElement).marginLeft);
      track.style.transform = `translateX(-${offset}px)`;

      dotsContainer.querySelectorAll('.dot').forEach((d, i) => {
        d.classList.toggle('active', i === current);
      });
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    // Drag support
    let isDragging = false;
    let startX = 0;
    let startTranslate = 0;

    track.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      const transform = getComputedStyle(track).transform;
      startTranslate = transform !== 'none' ? new DOMMatrix(transform).m41 : 0;
      track.classList.add('dragging');
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      track.style.transform = `translateX(${startTranslate + dx}px)`;
    });

    document.addEventListener('mouseup', (e) => {
      if (!isDragging) return;
      isDragging = false;
      track.classList.remove('dragging');
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 80) {
        goTo(current + (dx < 0 ? 1 : -1));
      } else {
        goTo(current);
      }
    });

    // Touch support
    track.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      const transform = getComputedStyle(track).transform;
      startTranslate = transform !== 'none' ? new DOMMatrix(transform).m41 : 0;
    }, { passive: true });

    track.addEventListener('touchmove', (e) => {
      const dx = e.touches[0].clientX - startX;
      track.style.transform = `translateX(${startTranslate + dx}px)`;
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      const dx = (e.changedTouches[0]?.clientX || 0) - startX;
      if (Math.abs(dx) > 50) {
        goTo(current + (dx < 0 ? 1 : -1));
      } else {
        goTo(current);
      }
    });
  }
</script>
