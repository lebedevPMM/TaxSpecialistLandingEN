---
const concepts = [
  { id: 'navy-sand', label: 'Navy & Sand', color: '#2B4C7E' },
  { id: 'warm-luxury', label: 'Warm Luxury', color: '#800020' },
  { id: 'minimal-authority', label: 'Minimal', color: '#1A1A1A' },
];
---

<div class="concept-switcher" id="concept-switcher">
  {concepts.map((c) => (
    <button
      class="concept-btn"
      data-concept-id={c.id}
      title={c.label}
    >
      <span class="concept-dot" style={`background: ${c.color};`}></span>
      <span class="concept-label">{c.label}</span>
    </button>
  ))}
</div>

<style>
  .concept-switcher {
    position: fixed;
    right: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 9998;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.5rem;
    background: color-mix(in srgb, var(--surface) 90%, transparent);
    border: 1px solid var(--border);
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0,0,0,0.2);
  }

  .concept-btn {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.7rem;
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    color: var(--text-muted);
  }
  .concept-btn:hover {
    color: var(--text);
    background: var(--glow);
  }
  .concept-btn.active {
    border-color: var(--accent);
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .concept-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .concept-btn.active .concept-dot {
    transform: scale(1.3);
    box-shadow: 0 0 8px currentColor;
  }

  .concept-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .concept-switcher {
      right: auto;
      left: 50%;
      top: auto;
      bottom: 1rem;
      transform: translateX(-50%);
      flex-direction: row;
    }
    .concept-label {
      display: none;
    }
    .concept-dot {
      width: 14px;
      height: 14px;
    }
    .concept-btn {
      padding: 0.5rem;
    }
  }
</style>

<script>
  function setConcept(id: string) {
    // Add transition class for smooth crossfade
    document.documentElement.classList.add('transitioning');
    document.documentElement.setAttribute('data-concept', id);
    localStorage.setItem('concept', id);

    // Update active button
    document.querySelectorAll('.concept-btn').forEach(btn => {
      const btnId = (btn as HTMLElement).dataset.conceptId;
      btn.classList.toggle('active', btnId === id);
    });

    // Remove transition class after animation completes
    setTimeout(() => {
      document.documentElement.classList.remove('transitioning');
    }, 700);
  }

  // Button click handlers
  document.querySelectorAll('.concept-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.conceptId;
      if (id) setConcept(id);
    });
  });

  // Set initial active state
  const saved = localStorage.getItem('concept') || 'noir-gold';
  setConcept(saved);
</script>
