---
const slides = [
  {
    id: 'securities',
    title: 'Securities\nand Assets',
    label: 'Securities',
    problems: [
      { id: 'p1', text: 'Asset freezes in Europe and the United States' },
      { id: 'p2', text: 'Segregation of securities on Type "C" accounts' },
      { id: 'p3', text: 'Termination of CFC servicing and banking relationships in the EU and offshore jurisdictions' },
    ],
    solutions: [
      { id: 's1', text: 'Obtaining individual licenses from Euroclear, Clearstream and OFAC', links: ['p1'] },
      { id: 's2', text: 'Interaction with the NSD and the Government Commission of the Russian Federation', links: ['p1', 'p2'] },
      { id: 's3', text: 'Sanctions-compliant KYC updates in registries and banks', links: ['p2', 'p3'] },
    ],
  },
  {
    id: 'taxes',
    title: 'International\nTax',
    label: 'Tax',
    problems: [
      { id: 'p1', text: 'Double taxation risks' },
      { id: 'p2', text: 'CFC risks and non-compliance with currency legislation' },
      { id: 'p3', text: 'Sanctions-related restrictions' },
    ],
    solutions: [
      { id: 's1', text: 'Structural review under applicable DTTs, monitoring of tax exposure', links: ['p1'] },
      { id: 's2', text: 'CFC compliance: notifications, reporting, 3-NDFL, ODDS', links: ['p2'] },
      { id: 's3', text: 'Compliant payment routes and cross-border trade logistics', links: ['p3'] },
    ],
  },
  {
    id: 'corporate',
    title: 'Corporate\nLaw',
    label: 'Corporate',
    problems: [
      { id: 'p1', text: 'Banking compliance and service refusals' },
      { id: 'p2', text: 'Loss of control over CFCs and offshore structures' },
      { id: 'p3', text: 'Business and team relocation' },
    ],
    solutions: [
      { id: 's1', text: 'Residence permits, company formation and bank accounts in new jurisdictions', links: ['p1', 'p3'] },
      { id: 's2', text: 'Client verification and compliance-driven business structuring', links: ['p1', 'p2'] },
      { id: 's3', text: '45+ corporate restructurings, redomiciliation to SARs, Cyprus, UAE', links: ['p2', 'p3'] },
    ],
  },
];
---

<section class="sc-section dark-section" id="services-carousel">
  <!-- Animated mesh gradient background -->
  <div class="sc-mesh-bg">
    <div class="mesh-blob mb-1"></div>
    <div class="mesh-blob mb-2"></div>
    <div class="mesh-blob mb-3"></div>
    <div class="mesh-blob mb-4"></div>
  </div>
  <div class="sc-mesh-noise"></div>

  <div class="sc-content">
    <!-- Carousel viewport -->
    <div class="sc-viewport">
      <div class="sc-track" id="sc-track">
        {slides.map((slide, i) => (
          <div class="sc-slide" data-index={i} data-slide-id={slide.id}>
            <div class="container mx-auto px-4 max-w-6xl">
              <div class="sc-slide-content">
                <div class="sc-decor" aria-hidden="true"></div>
                <h2 class="sc-title" set:html={slide.title.replace('\n', '<br/>')} />

                <div class="ps-grid" data-ps-grid={i}>
                  <!-- Problems column -->
                  <div class="ps-column">
                    <div class="ps-column-label">Key Challenges</div>
                    {slide.problems.map((p) => (
                      <div class="ps-card ps-card--problem" data-problem={p.id}>
                        <div class="ps-card-inner">
                          <svg class="ps-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                          </svg>
                          <p class="ps-card-text">{p.text}</p>
                        </div>
                      </div>
                    ))}
                  </div>

                  <!-- Solutions column -->
                  <div class="ps-column">
                    <div class="ps-column-label ps-column-label--gold">Solutions</div>
                    {slide.solutions.map((s) => (
                      <div class="ps-card ps-card--solution" data-solution={s.id} data-links={s.links.join(',')}>
                        <div class="ps-card-inner">
                          <svg class="ps-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                          </svg>
                          <p class="ps-card-text">{s.text}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation arrows -->
      <button class="sc-arrow sc-arrow--prev" id="sc-prev" aria-label="Previous">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="sc-arrow sc-arrow--next" id="sc-next" aria-label="Next">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  /* ===== Section ===== */
  .sc-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 0 4rem;
    background: #000;
    color: var(--text);
    position: relative;
    overflow: hidden;
  }

  /* ===== Animated mesh gradient background ===== */
  .sc-mesh-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    filter: blur(80px) saturate(1.6);
  }

  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
  }

  .mesh-blob.mb-1 {
    width: 60%;
    height: 60%;
    top: -10%;
    left: -10%;
    background: radial-gradient(circle, rgba(43, 76, 126, 0.18) 0%, transparent 70%);
    animation: meshDrift1 12s ease-in-out infinite alternate;
  }
  .mesh-blob.mb-2 {
    width: 50%;
    height: 50%;
    bottom: -15%;
    right: -10%;
    background: radial-gradient(circle, rgba(212, 184, 150, 0.12) 0%, transparent 70%);
    animation: meshDrift2 15s ease-in-out infinite alternate;
  }
  .mesh-blob.mb-3 {
    width: 40%;
    height: 40%;
    top: 30%;
    left: 40%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
    animation: meshDrift3 10s ease-in-out infinite alternate;
  }
  .mesh-blob.mb-4 {
    width: 35%;
    height: 35%;
    top: 60%;
    left: 10%;
    background: radial-gradient(circle, rgba(43, 76, 126, 0.14) 0%, transparent 70%);
    animation: meshDrift4 18s ease-in-out infinite alternate;
  }

  .sc-mesh-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    pointer-events: none;
  }

  @keyframes meshDrift1 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(15%, 10%) scale(1.15); }
    100% { transform: translate(5%, 20%) scale(1.05); }
  }
  @keyframes meshDrift2 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-20%, -10%) scale(1.2); }
    100% { transform: translate(-10%, 5%) scale(0.95); }
  }
  @keyframes meshDrift3 {
    0% { transform: translate(0, 0) scale(1); opacity: 0.8; }
    50% { transform: translate(-15%, 15%) scale(1.3); opacity: 1; }
    100% { transform: translate(10%, -10%) scale(1.1); opacity: 0.6; }
  }
  @keyframes meshDrift4 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(20%, -15%) scale(1.1); }
    100% { transform: translate(-5%, -5%) scale(1.2); }
  }

  /* ===== Content wrapper ===== */
  .sc-content {
    position: relative;
    z-index: 10;
    width: 100%;
  }

  /* ===== Carousel viewport ===== */
  .sc-viewport {
    position: relative;
    overflow: hidden;
  }

  .sc-track {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .sc-slide {
    min-width: 100%;
    flex-shrink: 0;
  }

  /* ===== Slide content ===== */
  .sc-slide-content {
    position: relative;
  }

  .sc-decor {
    width: 4rem;
    height: 2px;
    background: linear-gradient(to right, var(--accent), var(--accent-light));
    margin-bottom: 2.5rem;
    box-shadow: 0 0 16px rgba(43, 76, 126, 0.4);
  }

  .sc-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6.5vw, 5.5rem);
    font-weight: 300;
    color: var(--text);
    line-height: 1.08;
    margin-bottom: 3.5rem;
    text-shadow: 0 0 60px rgba(43, 76, 126, 0.1);
  }

  /* ===== Navigation arrows ===== */
  .sc-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 20;
  }

  .sc-arrow:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
  }

  .sc-arrow svg {
    width: 20px;
    height: 20px;
  }

  .sc-arrow--prev { left: 1.5rem; }
  .sc-arrow--next { right: 1.5rem; }

  .sc-arrow:disabled {
    opacity: 0.2;
    pointer-events: none;
  }

  /* ===== PS Grid (copied from BranchHero) ===== */
  .ps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .ps-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ps-column-label {
    text-transform: uppercase;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.5rem;
    padding-left: 0.5rem;
  }
  .ps-column-label--gold {
    color: rgba(255, 255, 255, 0.5);
  }

  .ps-card {
    border-radius: 24px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%);
    transition: all 0.5s var(--easing-smooth);
  }

  .ps-card-inner {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 23px;
    padding: 1.5rem 1.8rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    transition: all 0.5s var(--easing-smooth);
  }

  .ps-card-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    margin-top: 2px;
    stroke: rgba(255, 255, 255, 0.4);
    transition: stroke 0.4s ease;
  }

  .ps-card--solution {
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.03) 100%);
  }
  .ps-card--solution .ps-card-inner {
    background: rgba(255, 255, 255, 0.04);
  }
  .ps-card--solution .ps-card-icon {
    stroke: rgba(255, 255, 255, 0.5);
  }

  .ps-card-text {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    transition: color 0.4s ease;
  }

  /* Hover */
  .ps-card--problem:hover {
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.05) 100%);
    transform: rotate(-0.5deg) scale(1.02);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .ps-card--problem:hover .ps-card-inner {
    background: rgba(255, 255, 255, 0.08);
  }
  .ps-card--problem:hover .ps-card-text {
    color: #fff;
  }
  .ps-card--problem:hover .ps-card-icon {
    stroke: rgba(255, 255, 255, 0.8);
  }

  /* Highlighting mode */
  .ps-grid.highlighting .ps-card {
    opacity: 0.2;
    transform: scale(0.98);
  }
  .ps-grid.highlighting .ps-card.active-problem {
    opacity: 1;
    transform: scale(1);
  }
  .ps-grid.highlighting .ps-card.active-solution {
    opacity: 1;
    transform: rotate(-1deg) scale(1.02);
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.05) 100%);
    box-shadow: 0 8px 40px rgba(43, 76, 126, 0.2);
  }
  .ps-grid.highlighting .ps-card.active-solution .ps-card-inner {
    background: rgba(255, 255, 255, 0.06);
  }
  .ps-grid.highlighting .ps-card.active-solution .ps-card-text {
    color: #fff;
  }
  .ps-grid.highlighting .ps-card.active-solution .ps-card-icon {
    stroke: #fff;
  }

  /* ===== Mobile ===== */
  @media (max-width: 768px) {
    .sc-section {
      padding: 7rem 0 3rem;
      min-height: auto;
    }
    .sc-title {
      margin-bottom: 2rem;
    }
    .ps-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .ps-column { gap: 0.6rem; }
    .ps-card-inner { padding: 0.9rem 1.1rem; }
    .ps-card-text { font-size: 0.92rem; line-height: 1.5; }
    .ps-column-label { margin-bottom: 0.3rem; }
    .sc-arrow { display: none; }
  }
</style>

<script>
  // ===== Services Carousel =====
  const track = document.getElementById('sc-track') as HTMLElement;
  const prevBtn = document.getElementById('sc-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('sc-next') as HTMLButtonElement;
  const slideCount = 3;
  let currentSlide = 0;

  const hashMap: Record<string, number> = { securities: 0, taxes: 1, corporate: 2 };
  const idMap: string[] = ['securities', 'taxes', 'corporate'];

  function goToSlide(index: number, updateHash = true) {
    if (index < 0 || index >= slideCount) return;
    currentSlide = index;
    track.style.transform = `translateX(-${index * 100}%)`;

    // Update arrows
    prevBtn.disabled = index === 0;
    nextBtn.disabled = index === slideCount - 1;

    // Update hash
    if (updateHash) {
      history.replaceState(null, '', '#' + idMap[index]);
    }

    // Clear any active ps-grid highlights from previous slide
    document.querySelectorAll('.ps-grid.highlighting').forEach(g => {
      g.classList.remove('highlighting');
      g.querySelectorAll('.active-problem, .active-solution').forEach(el => {
        el.classList.remove('active-problem', 'active-solution');
      });
    });
  }

  // Init from hash
  const hash = location.hash.replace('#', '');
  if (hash in hashMap) {
    goToSlide(hashMap[hash], false);
  }

  // Arrow clicks
  prevBtn.addEventListener('click', () => goToSlide(currentSlide - 1));
  nextBtn.addEventListener('click', () => goToSlide(currentSlide + 1));

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') goToSlide(currentSlide - 1);
    if (e.key === 'ArrowRight') goToSlide(currentSlide + 1);
  });

  // Touch swipe
  let touchStartX = 0;
  let touchStartY = 0;
  let isSwiping = false;

  const viewport = track.parentElement!;
  viewport.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    isSwiping = false;
  }, { passive: true });

  viewport.addEventListener('touchmove', (e) => {
    const dx = e.touches[0].clientX - touchStartX;
    const dy = e.touches[0].clientY - touchStartY;
    // Only consider horizontal swipe if more horizontal than vertical
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
      isSwiping = true;
    }
  }, { passive: true });

  viewport.addEventListener('touchend', (e) => {
    if (!isSwiping) return;
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (dx < -50) goToSlide(currentSlide + 1);
    if (dx > 50) goToSlide(currentSlide - 1);
  });

  // ===== Problem-Solution highlighting (per slide) =====
  document.querySelectorAll('[data-ps-grid]').forEach(grid => {
    const problemCards = grid.querySelectorAll('[data-problem]');
    const solutionCards = grid.querySelectorAll('[data-solution]');
    const isMobile = window.matchMedia('(max-width: 768px)').matches;

    function clearHighlights() {
      grid.classList.remove('highlighting');
      grid.querySelectorAll('.active-problem, .active-solution').forEach(el => {
        el.classList.remove('active-problem', 'active-solution');
      });
    }

    function highlightProblem(card: Element) {
      const problemId = (card as HTMLElement).dataset.problem!;
      clearHighlights();
      grid.classList.add('highlighting');
      card.classList.add('active-problem');

      let firstSolution: Element | null = null;
      solutionCards.forEach(sol => {
        const links = (sol as HTMLElement).dataset.links?.split(',') || [];
        if (links.includes(problemId)) {
          sol.classList.add('active-solution');
          if (!firstSolution) firstSolution = sol;
        }
      });

      if (isMobile && firstSolution) {
        setTimeout(() => {
          (firstSolution as Element).scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 100);
      }
    }

    if (isMobile) {
      problemCards.forEach(card => {
        card.addEventListener('click', () => {
          if (card.classList.contains('active-problem')) {
            clearHighlights();
          } else {
            highlightProblem(card);
          }
        });
      });
      document.addEventListener('click', (e) => {
        if (!(e.target as Element).closest('.ps-card')) {
          clearHighlights();
        }
      });
    } else {
      problemCards.forEach(card => {
        card.addEventListener('mouseenter', () => highlightProblem(card));
        card.addEventListener('mouseleave', () => clearHighlights());
      });
    }
  });

  // Init arrow state
  prevBtn.disabled = currentSlide === 0;
  nextBtn.disabled = currentSlide === slideCount - 1;
</script>
