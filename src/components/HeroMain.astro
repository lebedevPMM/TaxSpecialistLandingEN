---

<section class="hero-wrap dark-section" id="hero-main">
  <div class="hero-card hero-card--editorial" id="heroCard">
    <!-- Animated mesh gradient background -->
    <div class="editorial-mesh-bg">
      <div class="mesh-blob mb-1"></div>
      <div class="mesh-blob mb-2"></div>
      <div class="mesh-blob mb-3"></div>
      <div class="mesh-blob mb-4"></div>
    </div>
    <div class="editorial-mesh-noise"></div>
    <div class="hero-editorial-composition">
      <div class="hero-editorial-photo">
        <img
          src="/TaxSpecialistLandingEN/hero3.jpg"
          alt="Investment Lawyer"
          class="hero-editorial-img"
          loading="eager"
        />
      </div>
      <div class="hero-editorial-text">
        <h1 class="hero-editorial-title">Investment<br/>Lawyer</h1>
        <div class="hero-editorial-buttons">
          <a href="/TaxSpecialistLandingEN/services/#securities" class="hero-btn-ghost">
            <span class="hero-btn-text"><span class="hl" style="--i:0">S</span><span class="hl" style="--i:1">e</span><span class="hl" style="--i:2">c</span><span class="hl" style="--i:3">u</span><span class="hl" style="--i:4">r</span><span class="hl" style="--i:5">i</span><span class="hl" style="--i:6">t</span><span class="hl" style="--i:7">i</span><span class="hl" style="--i:8">e</span><span class="hl" style="--i:9">s</span></span>
          </a>
          <a href="/TaxSpecialistLandingEN/services/#taxes" class="hero-btn-ghost">
            <span class="hero-btn-text"><span class="hl" style="--i:0">I</span><span class="hl" style="--i:1">n</span><span class="hl" style="--i:2">t</span><span class="hl" style="--i:3">e</span><span class="hl" style="--i:4">r</span><span class="hl" style="--i:5">n</span><span class="hl" style="--i:6">a</span><span class="hl" style="--i:7">t</span><span class="hl" style="--i:8">i</span><span class="hl" style="--i:9">o</span><span class="hl" style="--i:10">n</span><span class="hl" style="--i:11">a</span><span class="hl" style="--i:12">l</span><span class="hl" style="--i:13">&nbsp;</span><span class="hl" style="--i:14">T</span><span class="hl" style="--i:15">a</span><span class="hl" style="--i:16">x</span></span>
          </a>
          <a href="/TaxSpecialistLandingEN/services/#corporate" class="hero-btn-ghost">
            <span class="hero-btn-text"><span class="hl" style="--i:0">C</span><span class="hl" style="--i:1">o</span><span class="hl" style="--i:2">r</span><span class="hl" style="--i:3">p</span><span class="hl" style="--i:4">o</span><span class="hl" style="--i:5">r</span><span class="hl" style="--i:6">a</span><span class="hl" style="--i:7">t</span><span class="hl" style="--i:8">e</span><span class="hl" style="--i:9">&nbsp;</span><span class="hl" style="--i:10">L</span><span class="hl" style="--i:11">a</span><span class="hl" style="--i:12">w</span></span>
          </a>
        </div>
        <p class="hero-editorial-desc">Capital protection in a sanctions-driven and highly regulated international environment.</p>
      </div>
    </div>

    <div class="hero-bottom-strip">
      <div class="hero-geo">
        <span class="geo-marker"></span>
        Russia&ensp;&bull;&ensp;Cyprus&ensp;&bull;&ensp;Belgium&ensp;&bull;&ensp;Switzerland&ensp;&bull;&ensp;UK&ensp;&bull;&ensp;UAE&ensp;&bull;&ensp;Turkey
      </div>
      <div class="hero-scroll-center">
        <svg class="scroll-arrow-icon" width="12" height="18" viewBox="0 0 12 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 0v14M1 10l5 5 5-5"/></svg>
      </div>
    </div>
  </div>
</section>


<style>
  /* ===== Hero Wrap ===== */
  .hero-wrap {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-card--editorial {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding: 0;
    background: #000;
  }

  /* Animated mesh gradient */
  .editorial-mesh-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    filter: blur(80px) saturate(1.6);
  }

  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: screen;
  }

  .mesh-blob.mb-1 {
    width: 60%;
    height: 60%;
    top: -10%;
    left: -10%;
    background: radial-gradient(circle, rgba(43, 76, 126, 0.18) 0%, transparent 70%);
    animation: meshDrift1 12s ease-in-out infinite alternate;
  }

  .mesh-blob.mb-2 {
    width: 50%;
    height: 50%;
    bottom: -15%;
    right: -10%;
    background: radial-gradient(circle, rgba(212, 184, 150, 0.12) 0%, transparent 70%);
    animation: meshDrift2 15s ease-in-out infinite alternate;
  }

  .mesh-blob.mb-3 {
    width: 40%;
    height: 40%;
    top: 30%;
    left: 40%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
    animation: meshDrift3 10s ease-in-out infinite alternate;
  }

  .mesh-blob.mb-4 {
    width: 35%;
    height: 35%;
    top: 60%;
    left: 10%;
    background: radial-gradient(circle, rgba(43, 76, 126, 0.14) 0%, transparent 70%);
    animation: meshDrift4 18s ease-in-out infinite alternate;
  }

  /* Film grain / noise overlay */
  .editorial-mesh-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    pointer-events: none;
  }

  @keyframes meshDrift1 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(15%, 10%) scale(1.15); }
    100% { transform: translate(5%, 20%) scale(1.05); }
  }
  @keyframes meshDrift2 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-20%, -10%) scale(1.2); }
    100% { transform: translate(-10%, 5%) scale(0.95); }
  }
  @keyframes meshDrift3 {
    0% { transform: translate(0, 0) scale(1); opacity: 0.8; }
    50% { transform: translate(-15%, 15%) scale(1.3); opacity: 1; }
    100% { transform: translate(10%, -10%) scale(1.1); opacity: 0.6; }
  }
  @keyframes meshDrift4 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(20%, -15%) scale(1.1); }
    100% { transform: translate(-5%, -5%) scale(1.2); }
  }

  .hero-editorial-composition {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(3rem, 7vw, 7rem);
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(2rem, 5vw, 5rem);
    box-sizing: border-box;
    flex: 1;
  }

  .hero-editorial-photo {
    flex-shrink: 0;
    width: 400px;
    height: 440px;
    overflow: hidden;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow:
      0 40px 80px rgba(0, 0, 0, 0.8),
      0 15px 30px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.03);
  }

  .hero-editorial-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 10%;
    filter: contrast(1.1) brightness(0.92) saturate(0.85);
  }

  .hero-editorial-text {
    flex: 1;
    min-width: 0;
    max-width: 520px;
  }

  .hero-editorial-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
    font-weight: 300;
    color: #fff;
    line-height: 1.1;
    letter-spacing: 0.01em;
    margin: 0 0 2rem;
  }

  .hero-editorial-buttons {
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
    margin-bottom: 1.5rem;
  }

  .hero-btn-ghost {
    --btn-accent: var(--accent, #2B4C7E);
    --btn-highlight: var(--highlight, #D4B896);
    --btn-transition: 0.4s;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.3rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: all var(--btn-transition) ease;
    white-space: nowrap;
    backdrop-filter: blur(8px);
  }

  .hero-editorial-buttons {
    gap: 0.5rem;
  }

  /* Bottom glow layer — ::after */
  .hero-btn-ghost::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(0deg, var(--btn-highlight), var(--btn-accent), transparent 60%);
    opacity: 0;
    transition: opacity var(--btn-transition), filter var(--btn-transition);
    z-index: 1;
  }

  /* Letter styling */
  .hero-btn-text {
    position: relative;
    z-index: 2;
    display: inline-flex;
  }

  .hl {
    display: inline-block;
    color: rgba(255, 255, 255, 0.55);
    animation: heroLetterPulse 2.5s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.1s);
    transition: color var(--btn-transition), text-shadow var(--btn-transition);
  }

  @keyframes heroLetterPulse {
    0%, 100% {
      color: rgba(255, 255, 255, 0.5);
      text-shadow: none;
    }
    50% {
      color: rgba(255, 255, 255, 0.9);
      text-shadow: 0 0 6px rgba(212, 184, 150, 0.3);
    }
  }

  /* Hover */
  .hero-btn-ghost:hover {
    border-color: rgba(43, 76, 126, 0.5);
    background: rgba(43, 76, 126, 0.08);
    box-shadow:
      0 0 20px rgba(43, 76, 126, 0.15),
      0 0 40px rgba(43, 76, 126, 0.08);
  }
  .hero-btn-ghost:hover::after {
    opacity: 0.15;
    mask-image: linear-gradient(0deg, #fff, transparent);
    -webkit-mask-image: linear-gradient(0deg, #fff, transparent);
  }
  .hero-btn-ghost:hover .hl {
    animation: none;
    color: #fff;
    text-shadow: 0 0 8px rgba(212, 184, 150, 0.4);
  }

  /* Active / tap */
  .hero-btn-ghost:active {
    border-color: rgba(43, 76, 126, 0.7);
    background: rgba(43, 76, 126, 0.15);
    transform: scale(0.97);
  }
  .hero-btn-ghost:active::after {
    opacity: 0.3;
    mask-image: linear-gradient(0deg, #fff, transparent);
    -webkit-mask-image: linear-gradient(0deg, #fff, transparent);
    filter: brightness(1.5);
  }
  .hero-btn-ghost:active .hl {
    color: var(--btn-highlight);
    text-shadow: 0 0 4px rgba(212, 184, 150, 0.6);
    animation: none;
  }

  .hero-editorial-desc {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
    margin: 0;
  }

  /* Bottom strip */
  .hero-bottom-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 1.2rem 2rem;
  }

  .hero-geo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .geo-marker {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--highlight, #D4B896);
    border-radius: 50%;
    opacity: 0.6;
    animation: geoPulse 3s ease-in-out infinite;
  }

  @keyframes geoPulse {
    0%, 100% { opacity: 0.3; box-shadow: 0 0 0 0 rgba(212, 184, 150, 0.4); }
    50% { opacity: 0.8; box-shadow: 0 0 8px 2px rgba(212, 184, 150, 0.3); }
  }

  .hero-scroll-center {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-arrow-icon {
    color: var(--highlight, #D4B896);
    animation: scrollArrowBounce 2s ease-in-out infinite;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .hero-editorial-photo {
      width: 340px;
      height: 390px;
    }
  }

  @media (max-width: 768px) {
    .hero-editorial-composition {
      flex-direction: column;
      text-align: center;
      gap: 2.5rem;
      padding-top: 5rem;
    }
    .hero-editorial-photo {
      width: 280px;
      height: 310px;
    }
    .hero-editorial-text {
      max-width: 100%;
    }
    .hero-editorial-buttons {
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .hero-btn-ghost {
      padding: 0.6rem 0.9rem;
      font-size: 0.7rem;
    }
    .hl {
      animation-duration: 3s;
    }
    .hero-bottom-strip {
      position: relative;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.5rem 0;
    }
    .hero-geo {
      font-size: 0.6rem;
      white-space: normal;
      text-align: center;
      justify-content: center;
      flex-wrap: wrap;
    }
  }
</style>

<script>
  // ===== Hero animations (GSAP-powered) =====
  const gsap = (window as any).gsap;
  const ScrollTrigger = (window as any).ScrollTrigger;

  if (gsap && ScrollTrigger) {
    const heroCard = document.getElementById('heroCard');
    if (heroCard) {
      ScrollTrigger.create({
        trigger: '#hero-main',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
        onUpdate: (self: any) => {
          const p = self.progress;
          const scale = 1 - p * 0.05;
          const radius = p * 32;
          heroCard.style.transform = `scale(${scale})`;
          heroCard.style.borderRadius = `${radius}px`;
        }
      });
    }
  }
</script>
