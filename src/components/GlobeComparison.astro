---
---

<section class="globe-compare" id="globe-compare">
  <h2 class="compare-title">Сравнение глобусов</h2>
  <div class="compare-grid">
    <!-- Current: D3 wireframe -->
    <div class="compare-card">
      <div class="compare-label">Текущий — D3 wireframe</div>
      <div class="compare-canvas-wrap">
        <canvas id="globe-d3-compare"></canvas>
      </div>
    </div>

    <!-- New: COBE WebGL -->
    <div class="compare-card">
      <div class="compare-label">Вариант — COBE WebGL</div>
      <div class="compare-canvas-wrap">
        <canvas id="globe-cobe"></canvas>
      </div>
    </div>
  </div>
</section>

<style>
  .globe-compare {
    padding: 4rem 2rem;
    background: var(--bg);
    text-align: center;
  }

  .compare-title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 2rem;
  }

  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .compare-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .compare-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .compare-canvas-wrap {
    width: 400px;
    height: 400px;
    position: relative;
  }

  .compare-canvas-wrap canvas {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 900px) {
    .compare-grid { grid-template-columns: 1fr; }
    .compare-canvas-wrap { width: 300px; height: 300px; }
  }
</style>

<script>
  // ===== D3 wireframe globe (same as Geography section) =====
  const d3lib = (window as any).d3;

  if (d3lib) {
    const canvas = document.getElementById('globe-d3-compare') as HTMLCanvasElement;
    if (canvas) {
      const context = canvas.getContext('2d');
      if (context) {
        const size = 400;
        const radius = size / 2.5;

        const dpr = window.devicePixelRatio || 1;
        canvas.width = size * dpr;
        canvas.height = size * dpr;
        canvas.style.width = `${size}px`;
        canvas.style.height = `${size}px`;
        context.scale(dpr, dpr);

        const projection = d3lib.geoOrthographic()
          .scale(radius)
          .translate([size / 2, size / 2])
          .clipAngle(90);

        const path = d3lib.geoPath().projection(projection).context(context);

        const gridColor = 'rgba(42, 38, 34, 0.12)';
        const dotColor = 'rgba(43, 76, 126, 0.7)';
        const outlineColor = 'rgba(42, 38, 34, 0.3)';
        const globeStroke = 'rgba(42, 38, 34, 0.18)';

        interface DotData { lng: number; lat: number; }
        const allDots: DotData[] = [];
        let landFeatures: any = null;

        const pointInPolygon = (point: [number, number], polygon: number[][]): boolean => {
          const [x, y] = point;
          let inside = false;
          for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
            const [xi, yi] = polygon[i];
            const [xj, yj] = polygon[j];
            if (yi > y !== yj > y && x < ((xj - xi) * (y - yi)) / (yj - yi) + xi) {
              inside = !inside;
            }
          }
          return inside;
        };

        const pointInFeature = (point: [number, number], feature: any): boolean => {
          const geom = feature.geometry;
          if (geom.type === 'Polygon') {
            if (!pointInPolygon(point, geom.coordinates[0])) return false;
            for (let i = 1; i < geom.coordinates.length; i++) {
              if (pointInPolygon(point, geom.coordinates[i])) return false;
            }
            return true;
          } else if (geom.type === 'MultiPolygon') {
            for (const polygon of geom.coordinates) {
              if (pointInPolygon(point, polygon[0])) {
                let inHole = false;
                for (let i = 1; i < polygon.length; i++) {
                  if (pointInPolygon(point, polygon[i])) { inHole = true; break; }
                }
                if (!inHole) return true;
              }
            }
          }
          return false;
        };

        const generateDots = (feature: any, spacing = 18) => {
          const dots: [number, number][] = [];
          const bounds = d3lib.geoBounds(feature);
          const [[minLng, minLat], [maxLng, maxLat]] = bounds;
          const step = spacing * 0.08;
          for (let lng = minLng; lng <= maxLng; lng += step) {
            for (let lat = minLat; lat <= maxLat; lat += step) {
              const pt: [number, number] = [lng, lat];
              if (pointInFeature(pt, feature)) dots.push(pt);
            }
          }
          return dots;
        };

        const render = () => {
          context.clearRect(0, 0, size, size);
          context.beginPath();
          context.arc(size / 2, size / 2, projection.scale(), 0, 2 * Math.PI);
          context.fillStyle = 'rgba(43, 76, 126, 0.06)';
          context.fill();
          context.strokeStyle = globeStroke;
          context.lineWidth = 1.5;
          context.stroke();

          if (landFeatures) {
            const graticule = d3lib.geoGraticule();
            context.beginPath();
            path(graticule());
            context.strokeStyle = gridColor;
            context.lineWidth = 0.5;
            context.stroke();

            context.beginPath();
            landFeatures.features.forEach((f: any) => path(f));
            context.strokeStyle = outlineColor;
            context.lineWidth = 0.8;
            context.stroke();

            allDots.forEach((dot) => {
              const projected = projection([dot.lng, dot.lat]);
              if (projected && projected[0] >= 0 && projected[0] <= size && projected[1] >= 0 && projected[1] <= size) {
                context.beginPath();
                context.arc(projected[0], projected[1], 1, 0, 2 * Math.PI);
                context.fillStyle = dotColor;
                context.fill();
              }
            });
          }
        };

        const loadData = async () => {
          try {
            const res = await fetch('https://raw.githubusercontent.com/martynafford/natural-earth-geojson/refs/heads/master/110m/physical/ne_110m_land.json');
            if (!res.ok) return;
            landFeatures = await res.json();
            landFeatures.features.forEach((feature: any) => {
              generateDots(feature, 18).forEach(([lng, lat]) => {
                allDots.push({ lng, lat });
              });
            });
            render();
          } catch (e) {}
        };

        const rotation: [number, number] = [0, -15];
        const timer = d3lib.timer(() => {
          rotation[0] += 0.3;
          projection.rotate(rotation);
          render();
        });

        loadData();
        document.addEventListener('astro:before-swap', () => timer.stop(), { once: true });
      }
    }
  }

  // ===== COBE WebGL globe =====
  import createGlobe from 'cobe';

  const cobeCanvas = document.getElementById('globe-cobe') as HTMLCanvasElement;
  if (cobeCanvas) {
    let phi = 0;

    const size = cobeCanvas.parentElement!.offsetWidth;

    const globe = createGlobe(cobeCanvas, {
      devicePixelRatio: 2,
      width: size * 2,
      height: size * 2,
      phi: 0,
      theta: 0.3,
      dark: 0,
      diffuse: 1.2,
      mapSamples: 16000,
      mapBrightness: 6,
      baseColor: [0.97, 0.96, 0.94],        // warm cream (#F7F5F0)
      markerColor: [0.17, 0.30, 0.49],       // navy (#2B4C7E)
      glowColor: [0.97, 0.96, 0.94],         // match bg
      markers: [
        // Russia / CIS
        { location: [55.7558, 37.6173], size: 0.1 },    // Moscow
        // Cyprus
        { location: [34.6786, 33.0413], size: 0.06 },
        // Belgium / Luxembourg
        { location: [50.8503, 4.3517], size: 0.05 },
        { location: [49.6117, 6.1319], size: 0.04 },
        // Switzerland
        { location: [46.9480, 7.4474], size: 0.05 },
        // UK
        { location: [51.5074, -0.1278], size: 0.07 },
        // France
        { location: [48.8566, 2.3522], size: 0.05 },
        // UAE
        { location: [25.2048, 55.2708], size: 0.07 },
        // Turkey
        { location: [41.0082, 28.9784], size: 0.06 },
        // Spain
        { location: [40.4168, -3.7038], size: 0.05 },
      ],
      onRender: (state) => {
        state.phi = phi;
        phi += 0.005;
        state.width = size * 2;
        state.height = size * 2;
      },
    });

    cobeCanvas.style.opacity = '1';

    document.addEventListener('astro:before-swap', () => globe.destroy(), { once: true });
  }
</script>
